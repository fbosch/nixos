{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "~/dotfiles/**": "allow",
      "/nix/store/**": "allow"
    }
  },
  "references": {
    "dotfiles": {
      "path": "~/dotfiles",
      "description": "Personal dotfiles configuration"
    }
  },
  "mcp": {
    "nixos": {
      "type": "local",
      "command": [
        "podman",
        "run",
        "--rm",
        "-i",
        "ghcr.io/utensils/mcp-nixos"
      ]
    }
  },
  "formatter": {
    "nixpkgs-fmt": {
      "command": [
        "nix",
        "run",
        "nixpkgs#nixpkgs-fmt",
        "--",
        "$FILE"
      ],
      "extensions": [
        ".nix"
      ]
    },
    "statix": {
      "command": [
        "nix",
        "run",
        "nixpkgs#statix",
        "--",
        "check",
        "$FILE"
      ],
      "extensions": [
        ".nix"
      ]
    }
  }
}
