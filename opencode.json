{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "~/dotfiles/**": "allow",
      "/nix/store/**": "allow"
    }
  },
  "mcp": {
    "nixos": {
      "type": "local",
      "command": [
        "podman",
        "run",
        "--rm",
        "-i",
        "ghcr.io/utensils/mcp-nixos"
      ]
    }
  },
  "provider": {
    "headroom": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Headroom Proxy",
      "options": {
        "baseURL": "http://127.0.0.1:8787/v1"
      }
    }
  },
  "formatter": {
    "nixpkgs-fmt": {
      "command": [
        "nixpkgs-fmt",
        "--run",
        "nixpkgs-fmt $FILE"
      ],
      "extensions": [
        ".nix"
      ]
    },
    "statix": {
      "command": [
        "statix",
        "--run",
        "statix check $FILE"
      ],
      "extensions": [
        ".nix"
      ]
    }
  }
}
